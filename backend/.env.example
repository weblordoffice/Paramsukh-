PORT=3000
MONGO_URI=mongodb://user:password@host:27017/dbname
JWT_SECRET=CHANGE_ME_generated_via_openssl_rand_base64_32
ADMIN_JWT_SECRET=CHANGE_ME_generated_via_openssl_rand_base64_32
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Super Admin (created by: npm run seed-admin)
SUPER_ADMIN_EMAIL=admin@example.com

# Fast2SMS / SMS Provider Configuration
FAST2SMS_API_KEY=test

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret

# Admin API Key (internal auth between admin panel and backend)
ADMIN_API_KEY=CHANGE_ME_generated_random_string

# Resend Email
RESEND_API_KEY=re_xxx

# SMS Gateway
OTP_SMS_API_KEY=your_sms_key
OTP_SMS_BASE_URL=https://your-sms-provider.com/api
OTP_SMS_SENDER=YourSender
OTP_SMS_ENTITY_ID=your_entity_id
OTP_SMS_TEMPLATE_ID=your_template_id

# Clerk (for Clerk webhook verification on backend)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# AI Service
AI_SERVICE_BASE_URL=http://127.0.0.1:8011
AI_SERVICE_SHARED_SECRET=CHANGE_ME
